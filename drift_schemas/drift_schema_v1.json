  "fixed_sql": [
    {
      "name": "seasons",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"seasons\" (\"year\" INTEGER NOT NULL, \"label\" TEXT NULL, \"status\" TEXT NOT NULL, \"start_date\" TEXT NULL, \"end_date\" TEXT NULL, \"round_count\" INTEGER NULL, \"current_round\" INTEGER NULL, \"is_current\" INTEGER NOT NULL DEFAULT 0 CHECK (\"is_current\" IN (0, 1)), PRIMARY KEY (\"year\"));"
        }
      ]
    },
    {
      "name": "circuits",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"circuits\" (\"id\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"locality\" TEXT NULL, \"country\" TEXT NULL, \"country_code\" TEXT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "grand_prix",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"grand_prix\" (\"id\" TEXT NOT NULL, \"season\" INTEGER NOT NULL REFERENCES seasons (year) ON DELETE NO ACTION, \"round\" INTEGER NOT NULL, \"event_slug\" TEXT NOT NULL, \"name\" TEXT NOT NULL, \"official_name\" TEXT NULL, \"circuit_id\" TEXT NOT NULL REFERENCES circuits (id) ON DELETE NO ACTION, \"status\" TEXT NOT NULL, \"format\" TEXT NOT NULL, \"start_date\" TEXT NULL, \"end_date\" TEXT NULL, \"timezone\" TEXT NULL, \"has_results\" INTEGER NOT NULL DEFAULT 0 CHECK (\"has_results\" IN (0, 1)), PRIMARY KEY (\"id\"), UNIQUE (\"season\", \"round\"));"
        }
      ]
    },
    {
      "name": "sessions",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"sessions\" (\"id\" TEXT NOT NULL, \"grand_prix_id\" TEXT NOT NULL REFERENCES grand_prix (id) ON DELETE CASCADE, \"type\" TEXT NOT NULL, \"name\" TEXT NULL, \"start_time_utc\" TEXT NULL, \"end_time_utc\" TEXT NULL, \"status\" TEXT NOT NULL, \"order_index\" INTEGER NOT NULL, PRIMARY KEY (\"id\"));"
        }
      ]
    },
    {
      "name": "snapshots",
      "sql": [
        {
          "dialect": "sqlite",
          "sql": "CREATE TABLE IF NOT EXISTS \"snapshots\" (\"key\" TEXT NOT NULL, \"generated_at\" TEXT NOT NULL, \"source_updated_at\" TEXT NULL, \"stale_after\" TEXT NULL, \"content_version\" TEXT NULL, \"server_stale\" INTEGER NULL CHECK (\"server_stale\" IN (0, 1)), \"focus_season\" INTEGER NULL, \"focus_round\" INTEGER NULL, PRIMARY KEY (\"key\"));"
        }
      ]
    }
  ]
