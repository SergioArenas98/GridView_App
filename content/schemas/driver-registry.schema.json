{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gridview.local/schemas/driver-registry.schema.json",
  "title": "GridView driver registry (curated stable identity)",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "status", "drivers"],
  "properties": {
    "kind": { "const": "driver-registry" },
    "status": { "$ref": "common.schema.json#/$defs/mockStatus" },
    "note": { "type": "string" },
    "drivers": {
      "type": "array",
      "items": { "$ref": "#/$defs/registryDriver" }
    }
  },
  "$defs": {
    "registryDriver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "fullName"],
      "properties": {
        "id": { "$ref": "common.schema.json#/$defs/slug" },
        "fullName": { "type": "string", "minLength": 1 },
        "givenName": { "type": ["string", "null"] },
        "familyName": { "type": ["string", "null"] },
        "shortCode": { "type": ["string", "null"] },
        "permanentNumber": { "type": ["integer", "null"] },
        "nationality": { "type": ["string", "null"] },
        "countryCode": { "anyOf": [{ "$ref": "common.schema.json#/$defs/countryCode" }, { "type": "null" }] },
        "dateOfBirth": { "anyOf": [{ "$ref": "common.schema.json#/$defs/date" }, { "type": "null" }] },
        "placeOfBirth": { "type": ["string", "null"] },
        "biography": { "type": ["string", "null"] }
      }
    }
  }
}
