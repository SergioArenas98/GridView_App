{
  "name": "gridview-edge-api",
  "version": "0.1.0",
  "private": true,
  "description": "GridView edge API - Cloudflare Worker serving the GridView API contract.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "vitest run",
    "validate:openapi": "redocly lint ../../docs/api/gridview-api-v1.yaml --config ../../redocly.yaml",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:fixtures": "node scripts/validate-fixtures.mjs",
    "validate": "npm run validate:openapi && npm run validate:content && npm run validate:fixtures"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260718.1",
    "@eslint/js": "^10.0.1",
    "@redocly/cli": "^2.39.0",
    "@types/js-yaml": "^4.0.9",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^10.7.0",
    "globals": "^16.5.0",
    "js-yaml": "^4.3.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
